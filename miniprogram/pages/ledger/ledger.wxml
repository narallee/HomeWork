<view class="container">
  <view class="action-bar flex-between">
    <text class="page-title">账本管理</text>
    <view class="action-btns">
      <text class="action-btn" bindtap="showJoin">加入</text>
      <text class="action-btn primary" bindtap="showCreate">新建</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-tip">加载中...</view>

  <!-- 空状态 -->
  <view wx:elif="{{ledgers.length === 0}}" class="empty-tip">暂无账本，点击"新建"创建一个吧</view>

  <!-- 账本列表 -->
  <view wx:else class="ledger-list">
    <view class="ledger-item card" wx:for="{{ledgers}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="flex-between">
        <text class="item-name">{{item.name}}</text>
        <text class="item-amount">¥ {{item.total_amount || '0.00'}}</text>
      </view>
      <view class="item-meta">
        <text>{{item.member_count}}位成员</text>
        <text class="item-role">{{item.role === 'owner' ? '我创建的' : '已加入'}}</text>
      </view>
    </view>
  </view>

  <!-- 创建账本弹窗 -->
  <view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="hideCreate">
    <view class="modal-content" catchtap="">
      <text class="modal-title">新建账本</text>
      <input class="modal-input" placeholder="账本名称" value="{{newLedgerName}}" bindinput="onNameInput" />
      <input class="modal-input" placeholder="账本描述（选填）" value="{{newLedgerDesc}}" bindinput="onDescInput" />
      <view class="modal-btns">
        <text class="modal-btn cancel" bindtap="hideCreate">取消</text>
        <text class="modal-btn confirm" bindtap="createLedger">创建</text>
      </view>
    </view>
  </view>

  <!-- 加入账本弹窗 -->
  <view class="modal-mask" wx:if="{{showJoinModal}}" bindtap="hideJoin">
    <view class="modal-content" catchtap="">
      <text class="modal-title">加入账本</text>
      <input class="modal-input" placeholder="请输入邀请码" value="{{inviteCode}}" bindinput="onCodeInput" />
      <view class="modal-btns">
        <text class="modal-btn cancel" bindtap="hideJoin">取消</text>
        <text class="modal-btn confirm" bindtap="joinLedger">加入</text>
      </view>
    </view>
  </view>
</view>
