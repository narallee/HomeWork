.location-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.map {
  flex: 1;
  width: 100%;
}

.control-panel {
  background: #fff;
  padding: 30rpx;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.panel-row {
  margin-bottom: 24rpx;
}

.panel-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.picker-btn {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.status-bar {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
  margin-right: 12rpx;
}

.status-dot.active {
  background: #27ae60;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

.status-text {
  font-size: 26rpx;
  color: #666;
}

.share-btn {
  width: 100%;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.share-btn.start {
  background: #4A90D9;
  color: #fff;
}

.share-btn.stop {
  background: #e74c3c;
  color: #fff;
}
