.range-switch {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.range-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.range-btn.active {
  background: #4A90D9;
  color: #fff;
}

.overview {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.overview-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.stat-list {
  margin-top: 10rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.stat-item:last-child {
  border-bottom: none;
}

.stat-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-name {
  font-size: 28rpx;
  color: #333;
}

.stat-type {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.stat-data {
  text-align: right;
}

.stat-amount {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
}

.stat-count {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.member-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}
