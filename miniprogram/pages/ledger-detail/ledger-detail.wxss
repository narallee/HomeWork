.ledger-header {
  margin-bottom: 30rpx;
}

.ledger-name {
  font-size: 36rpx;
  font-weight: bold;
}

.member-count {
  font-size: 24rpx;
  color: #999;
}

.ledger-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin: 10rpx 0 20rpx;
}

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 24rpx;
  color: #666;
}

.header-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.header-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx 20rpx;
  border: 1rpx solid #4A90D9;
  border-radius: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.add-record-btn {
  font-size: 26rpx;
  color: #4A90D9;
}

.record-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.record-info {
  flex: 1;
}

.record-category {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}

.record-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.record-amount {
  font-size: 34rpx;
  font-weight: bold;
}

.record-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #bbb;
}
