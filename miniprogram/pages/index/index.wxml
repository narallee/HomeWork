<view class="container">
  <view class="header">
    <text class="title">我的账本</text>
    <text class="subtitle">协作记账，轻松管理</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-tip">加载中...</view>

  <!-- 空状态 -->
  <view wx:elif="{{ledgers.length === 0}}" class="empty-state">
    <text class="empty-icon">📒</text>
    <text class="empty-text">还没有账本</text>
    <text class="empty-hint">去"账本"页面创建或加入一个账本吧</text>
  </view>

  <!-- 账本列表 -->
  <view wx:else class="ledger-list">
    <view class="ledger-card card" wx:for="{{ledgers}}" wx:key="id" bindtap="goToLedger" data-id="{{item.id}}">
      <view class="ledger-header flex-between">
        <text class="ledger-name">{{item.name}}</text>
        <text class="ledger-role">{{item.role === 'owner' ? '创建者' : '成员'}}</text>
      </view>
      <view class="ledger-info">
        <text class="ledger-desc">{{item.description || '暂无描述'}}</text>
      </view>
      <view class="ledger-footer flex-between">
        <view class="ledger-stats">
          <text class="stat-item">{{item.member_count}}人</text>
          <text class="stat-separator">·</text>
          <text class="stat-item">总计 ¥{{item.total_amount || '0.00'}}</text>
        </view>
        <view class="add-btn" catchtap="goToAdd" data-id="{{item.id}}">+ 记一笔</view>
      </view>
    </view>
  </view>
</view>
