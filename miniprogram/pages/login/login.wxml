<view class="login-page">
  <view class="login-header">
    <view class="logo-wrapper">
      <text class="logo-text">协作记账</text>
    </view>
    <text class="login-subtitle">多人协作记账 + 实时位置共享</text>
  </view>

  <view class="login-body">
    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-icon">📝</text>
        <text class="feature-text">多人协作记账</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📍</text>
        <text class="feature-text">实时位置共享</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <text class="feature-text">智能统计分析</text>
      </view>
    </view>
  </view>

  <view class="login-footer">
    <button class="login-btn" bindtap="handleLogin" loading="{{logging}}">
      微信一键登录
    </button>
    <text class="login-tip">登录即表示同意用户协议和隐私政策</text>
  </view>
</view>
