.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 100%);
  padding: 100rpx 60rpx 80rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.logo-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-body {
  width: 100%;
}

.feature-list {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #fff;
}

.login-footer {
  width: 100%;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #fff;
  color: #4A90D9;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.login-btn:active {
  background-color: #f0f0f0;
}

.login-tip {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}
