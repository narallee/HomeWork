.type-switch {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #666;
}

.type-btn.active {
  background: #4A90D9;
  color: #fff;
  font-weight: bold;
}

.amount-section {
  margin-bottom: 24rpx;
}

.amount-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
}

.currency-sign {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.amount-input {
  font-size: 48rpx;
  font-weight: bold;
  flex: 1;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.category-item.selected {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}

.desc-input {
  font-size: 28rpx;
  padding: 10rpx 0;
}

.date-picker {
  font-size: 28rpx;
  color: #333;
  padding: 10rpx 0;
}

.submit-btn {
  margin-top: 40rpx;
}
