.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.edit-hint {
  font-size: 26rpx;
  color: #4A90D9;
}

.menu-list {
  margin-bottom: 60rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rpx;
  border-radius: 0;
  padding: 30rpx;
}

.menu-item:first-child {
  border-radius: 12rpx 12rpx 0 0;
}

.menu-item:last-child {
  border-radius: 0 0 12rpx 12rpx;
  margin-bottom: 0;
}

.menu-label {
  font-size: 28rpx;
  color: #333;
}

.menu-value {
  font-size: 26rpx;
  color: #999;
}

.logout-btn {
  margin-top: 60rpx;
}
